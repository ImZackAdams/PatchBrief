<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="PatchBrief public feed: short operator-ready briefs on public vulnerability advisories, known exploited vulnerabilities, vendor updates, and threat activity." />
    <meta name="theme-color" content="#15211f" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="PatchBrief public feed | Security briefs for operators" />
    <meta property="og:description" content="Short source-backed briefs on public vulnerability advisories, exploited vulnerabilities, vendor updates, and threat activity." />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="PatchBrief public feed | Security briefs for operators" />
    <meta name="twitter:description" content="Short source-backed briefs on public vulnerability advisories, exploited vulnerabilities, vendor updates, and threat activity." />
    <link rel="alternate" type="application/rss+xml" title="PatchBrief RSS" href="/rss.xml" />
    <title>Public feed | PatchBrief</title>
    <style>
      :root {
        color-scheme: light;
        --page: #fbfbf8;
        --paper: #ffffff;
        --ink: #111816;
        --soft-ink: #2e3936;
        --muted: #66706d;
        --line: #e2e5df;
        --line-strong: #cdd3cc;
        --accent: #0f766e;
        --accent-soft: #edf7f4;
        --red: #913f32;
        --red-soft: #fdf0ee;
        --amber: #8a5c0f;
        --amber-soft: #fdf5e6;
        --max: 860px;
        --radius: 6px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--page);
        color: var(--ink);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a { color: inherit; }
      a:focus-visible, button:focus-visible, input:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
      h1, h2, h3, p { margin-top: 0; }
      h1 { margin-bottom: 0.75rem; font-size: clamp(1.9rem, 5vw, 2.8rem); font-weight: 760; line-height: 1.05; }
      h2 { margin-bottom: 0.35rem; font-size: 1rem; font-weight: 760; }
      p { margin-bottom: 0.8rem; }
      .wrap { width: min(calc(100% - 32px), var(--max)); margin: 0 auto; }
      header { border-bottom: 1px solid var(--line); background: rgba(251,251,248,0.96); backdrop-filter: blur(10px); position: sticky; top: 0; z-index: 10; }
      .nav { display: flex; min-height: 4rem; align-items: center; justify-content: space-between; gap: 1rem; }
      .brand { display: inline-flex; align-items: center; gap: 0.65rem; font-weight: 760; text-decoration: none; color: var(--ink); }
      .mark { display: grid; width: 2rem; height: 2rem; place-items: center; border: 1px solid var(--line-strong); border-radius: var(--radius); background: var(--paper); color: var(--accent); font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.78rem; font-weight: 800; }
      nav { display: flex; align-items: center; gap: 0.2rem; }
      nav a { border-radius: var(--radius); color: var(--muted); padding: 0.45rem 0.6rem; font-size: 0.92rem; text-decoration: none; }
      nav a:hover, nav a:focus-visible { color: var(--ink); }
      nav a.active { color: var(--ink); font-weight: 760; }
      .nav-cta { border: 1px solid var(--line-strong); background: var(--paper); color: var(--ink) !important; font-weight: 760; }
      .hero { border-bottom: 1px solid var(--line); background: var(--paper); padding: 3.5rem 0 2.5rem; }
      .eyebrow { margin-bottom: 0.65rem; color: var(--accent); font-size: 0.82rem; font-weight: 760; letter-spacing: 0.03em; text-transform: uppercase; }
      .hero-lede { max-width: 60ch; color: var(--soft-ink); font-size: clamp(1rem, 2vw, 1.15rem); margin-bottom: 0; }
      .sample-notice { margin: 1.5rem 0 0; padding: 0.7rem 0.9rem; border: 1px solid var(--line-strong); border-left: 3px solid var(--accent); border-radius: var(--radius); background: var(--accent-soft); color: var(--accent); font-size: 0.88rem; }

      /* Filter + search bar */
      .filter-bar { border-bottom: 1px solid var(--line); background: var(--page); padding: 0.75rem 0; }
      .filter-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.65rem; }
      .filter-chips { display: flex; flex-wrap: wrap; gap: 0.45rem; flex: 1; }
      .chip {
        display: inline-flex; align-items: center;
        border: 1px solid var(--line-strong); border-radius: 99px;
        background: var(--paper); color: var(--soft-ink);
        padding: 0.3rem 0.75rem; font-size: 0.82rem; font-weight: 720;
        cursor: pointer; user-select: none;
        transition: border-color 0.1s, background 0.1s, color 0.1s;
      }
      .chip:hover { border-color: var(--accent); color: var(--accent); }
      .chip.active { border-color: var(--accent); background: var(--accent-soft); color: var(--accent); }
      .search-wrap { position: relative; flex-shrink: 0; }
      .search-input {
        border: 1px solid var(--line-strong); border-radius: var(--radius);
        background: var(--paper); color: var(--ink);
        font: inherit; font-size: 0.88rem;
        padding: 0.35rem 0.7rem 0.35rem 2rem;
        width: 200px; transition: border-color 0.15s;
      }
      .search-input:focus { border-color: var(--accent); outline: none; }
      .search-icon {
        position: absolute; left: 0.55rem; top: 50%; transform: translateY(-50%);
        color: var(--muted); pointer-events: none; font-size: 0.85rem;
      }

      /* Feed count row */
      .feed-meta-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; }
      .feed-count { color: var(--muted); font-size: 0.85rem; }

      /* Empty state */
      .feed-empty { display: none; padding: 3rem 1.25rem; text-align: center; color: var(--muted); font-size: 0.95rem; }

      .feed-section { padding: 2rem 0 3rem; }
      .feed-list { display: grid; gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
      .feed-item { background: var(--paper); padding: 1.25rem; }
      .feed-item:hover { background: #fafaf8; }
      .feed-item-top { display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.6rem; }
      .feed-item-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem; }
      .feed-date { color: var(--muted); font-size: 0.82rem; }
      .type-badge { display: inline-flex; align-items: center; border: 1px solid var(--line-strong); border-radius: var(--radius); background: var(--page); color: var(--soft-ink); padding: 0.15rem 0.45rem; font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.73rem; font-weight: 700; }
      .signal-badge { display: inline-flex; align-items: center; border-radius: var(--radius); padding: 0.15rem 0.45rem; font-size: 0.73rem; font-weight: 760; }
      .signal-badge.exploited { background: var(--accent-soft); color: var(--accent); }
      .signal-badge.critical { background: var(--red-soft); color: var(--red); }
      .signal-badge.patch { background: var(--amber-soft); color: var(--amber); }
      .signal-badge.threat { background: #f0eefb; color: #5a3f9e; }
      .cve-tag { color: var(--muted); font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size: 0.73rem; }
      .feed-item-title { margin: 0 0 0.4rem; font-size: 1rem; font-weight: 760; line-height: 1.3; }
      .feed-item-title a { color: var(--ink); text-decoration: none; }
      .feed-item-title a:hover { color: var(--accent); }
      .feed-vendor { margin-bottom: 0.5rem; color: var(--muted); font-size: 0.86rem; }
      .feed-summary { color: var(--soft-ink); font-size: 0.93rem; margin-bottom: 0.65rem; }
      .feed-check { border-top: 1px solid var(--line); padding-top: 0.6rem; margin-top: 0.6rem; }
      .feed-check-label { color: var(--muted); font-size: 0.76rem; font-weight: 760; letter-spacing: 0.03em; text-transform: uppercase; margin-bottom: 0.2rem; }
      .feed-check p { color: var(--soft-ink); font-size: 0.88rem; margin-bottom: 0.5rem; }
      .feed-sources { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
      .feed-sources a { color: var(--accent); font-size: 0.83rem; font-weight: 760; text-decoration: none; border-bottom: 1px solid currentColor; }
      .feed-sources a:hover { color: var(--ink); }
      .feed-read-link { display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.65rem; color: var(--accent); font-size: 0.88rem; font-weight: 760; text-decoration: none; border-bottom: 1px solid transparent; }
      .feed-read-link:hover { border-bottom-color: currentColor; }

      /* Upgrade section */
      .upgrade-section { border-top: 1px solid var(--line); background: var(--paper); padding: 2.5rem 0; }
      .upgrade-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; border: 1px solid var(--line); border-radius: var(--radius); background: var(--line); overflow: hidden; }
      .upgrade-panel { background: var(--paper); padding: 1.75rem; }
      .upgrade-panel.upgrade-pro { background: var(--ink); color: #fff; }
      .upgrade-label { font-size: 0.75rem; font-weight: 760; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.4rem; }
      .upgrade-pro .upgrade-label { color: rgba(255,255,255,0.45); }
      .upgrade-heading { font-size: clamp(1.05rem, 2.5vw, 1.35rem); font-weight: 760; margin-bottom: 0.5rem; line-height: 1.25; }
      .upgrade-pro .upgrade-heading { color: #fff; }
      .upgrade-desc { font-size: 0.9rem; color: var(--soft-ink); margin-bottom: 1rem; max-width: 44ch; }
      .upgrade-pro .upgrade-desc { color: rgba(255,255,255,0.65); }
      .newsletter-row { display: flex; flex-wrap: wrap; gap: 0.6rem; }
      .newsletter-row input[type="email"] { flex: 1; min-width: 180px; border: 1px solid var(--line-strong); border-radius: var(--radius); background: var(--page); color: var(--ink); font: inherit; font-size: 0.9rem; padding: 0.65rem 0.8rem; }
      .newsletter-row input[type="email"]::placeholder { color: #89928f; }
      .newsletter-row input[type="email"]:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
      /* In-feed promo card */
      .feed-promo { background: var(--ink); padding: 1.25rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; }
      .feed-promo-text { flex: 1; min-width: 200px; }
      .feed-promo-text p { margin: 0; font-size: 0.88rem; font-weight: 760; color: #fff; }
      .feed-promo-text span { font-size: 0.82rem; color: rgba(255,255,255,0.55); font-weight: 400; }
      .button { display: inline-flex; min-height: 2.8rem; align-items: center; justify-content: center; border: 1px solid var(--line-strong); border-radius: var(--radius); background: var(--paper); padding: 0.72rem 0.95rem; cursor: pointer; color: var(--ink); font: inherit; font-weight: 760; text-decoration: none; white-space: nowrap; }
      .button:hover, .button:focus-visible { border-color: var(--ink); }
      .button.primary { border-color: var(--ink); background: var(--ink); color: #ffffff; }
      .button.primary:hover, .button.primary:focus-visible { background: var(--accent); border-color: var(--accent); }
      .button.button-white { border-color: #fff; background: #fff; color: var(--ink); }
      .button.button-white:hover { background: var(--accent-soft); border-color: var(--accent-soft); }
      .button.button-ghost { border-color: rgba(255,255,255,0.35); background: transparent; color: #fff; font-size: 0.85rem; min-height: 2.4rem; padding: 0.5rem 0.9rem; }
      .button.button-ghost:hover { border-color: #fff; }
      footer { border-top: 1px solid var(--line); padding: 1.5rem 0; }
      .footer-row { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; color: var(--muted); font-size: 0.9rem; }
      .footer-links { display: flex; flex-wrap: wrap; gap: 0.85rem; }
      .footer-links a { color: var(--muted); text-decoration: none; font-size: 0.9rem; }
      .footer-links a:hover { color: var(--ink); }
      footer strong { color: var(--ink); }
      @media (prefers-reduced-motion: reduce) { *, *::before, *::after { scroll-behavior: auto !important; transition: none !important; } }
      @media (max-width: 720px) {
        .wrap { width: min(calc(100% - 24px), var(--max)); }
        .nav { min-height: auto; align-items: flex-start; flex-direction: column; padding: 0.85rem 0; }
        nav { width: 100%; overflow-x: auto; padding-bottom: 0.15rem; }
        nav a { white-space: nowrap; }
        .hero { padding: 2.5rem 0 2rem; }
        .button { width: 100%; }
        .newsletter-row { flex-direction: column; }
        .newsletter-row input[type="email"], .newsletter-row .button { width: 100%; }
        .search-input { width: 100%; }
        .filter-row { flex-direction: column; align-items: flex-start; }
        .search-wrap { width: 100%; }
        .upgrade-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <a class="skip" href="#content">Skip to content</a>

    <header>
      <div class="wrap nav" aria-label="Primary navigation">
        <a class="brand" href="/">
          <span class="mark" aria-hidden="true">PB</span>
          <span>PatchBrief</span>
        </a>
        <nav>
          <a href="feed.html" class="active">Feed</a>
          <a href="pricing.html">Pricing</a>
          <a href="rss.xml">RSS</a>
          <a class="nav-cta" href="pricing.html#pro">Get Pro</a>
        </nav>
      </div>
    </header>

    <main id="content">
      <section class="hero">
        <div class="wrap">
          <p class="eyebrow">Public feed</p>
          <h1>Short security briefs for public vulnerability and threat signals.</h1>
          <p class="hero-lede">
            PatchBrief tracks public advisories, exploited vulnerabilities, vendor updates,
            and threat activity, then summarizes what operators may want to check.
          </p>
          ${SAMPLE_NOTICE}
        </div>
      </section>

      <div class="filter-bar">
        <div class="wrap">
          <div class="filter-row">
            <div class="filter-chips" role="list" aria-label="Filter by type">
              <button class="chip active" data-filter="all" role="listitem" aria-pressed="true">All</button>
              <button class="chip" data-filter="KEV" role="listitem" aria-pressed="false">KEV</button>
              <button class="chip" data-filter="Vendor advisory" role="listitem" aria-pressed="false">Vendor advisory</button>
              <button class="chip" data-filter="Patch Tuesday" role="listitem" aria-pressed="false">Patch Tuesday</button>
              <button class="chip" data-filter="Ransomware" role="listitem" aria-pressed="false">Ransomware</button>
              <button class="chip" data-filter="Exploit activity" role="listitem" aria-pressed="false">Exploit activity</button>
            </div>
            <div class="search-wrap">
              <span class="search-icon" aria-hidden="true">&#9906;</span>
              <input
                class="search-input"
                id="feed-search"
                type="search"
                placeholder="Search briefs&hellip;"
                aria-label="Search feed"
                autocomplete="off"
                spellcheck="false"
              />
            </div>
          </div>
        </div>
      </div>

      <section class="feed-section">
        <div class="wrap">
          <div class="feed-meta-row">
            <span class="feed-count" id="feed-count" aria-live="polite">${ITEM_COUNT} items</span>
          </div>
          <div class="feed-list" id="feed-list" aria-label="PatchBrief security feed">
            ${ITEMS_HTML}
            <div class="feed-empty" id="feed-empty" role="status">No briefs match this filter.</div>
          </div>
        </div>
      </section>

      <section class="upgrade-section" id="newsletter" aria-label="Subscribe or upgrade">
        <div class="wrap">
          <div class="upgrade-grid">
            <div class="upgrade-panel">
              <p class="upgrade-label">Free</p>
              <h2 class="upgrade-heading">Get the weekly digest by email.</h2>
              <p class="upgrade-desc">Top 5 exploited CVEs and critical advisories from the past week, every Monday.</p>
              <form
                action="https://formsubmit.co/87df02627dd3ab260cc04968fbe79bb7"
                method="POST"
              >
                <input type="hidden" name="_subject" value="New PatchBrief newsletter signup" />
                <input type="hidden" name="_template" value="table" />
                <input type="hidden" name="_cc" value="patchbrief@protonmail.com" />
                <input type="hidden" name="_next" value="https://www.patchbrief.org/?subscribed=1#newsletter" />
                <input type="hidden" name="interest_type" value="Free weekly digest" />
                <div class="newsletter-row">
                  <input name="email" type="email" autocomplete="email" placeholder="you@company.com" required />
                  <button class="button primary" type="submit">Subscribe free</button>
                </div>
              </form>
            </div>
            <div class="upgrade-panel upgrade-pro">
              <p class="upgrade-label">Pro &mdash; $9/mo</p>
              <h2 class="upgrade-heading">Daily digest + vendor watchlist alerts.</h2>
              <p class="upgrade-desc">Get this feed delivered every morning and receive targeted alerts when vulnerabilities hit vendors you run.</p>
              <a class="button button-white" href="pricing.html#pro">Upgrade to Pro &rarr;</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <div class="wrap footer-row">
        <strong>PatchBrief</strong>
        <div class="footer-links">
          <a href="feed.html">Feed</a>
          <a href="rss.xml">RSS</a>
          <a href="mailto:patchbrief@protonmail.com">patchbrief@protonmail.com</a>
        </div>
      </div>
    </footer>

    <script>
    (function () {
      var chips = document.querySelectorAll('.chip[data-filter]');
      var searchInput = document.getElementById('feed-search');
      var countEl = document.getElementById('feed-count');
      var emptyEl = document.getElementById('feed-empty');
      var feedList = document.getElementById('feed-list');
      var items = feedList ? feedList.querySelectorAll('.feed-item') : [];

      var activeFilter = 'all';
      var searchQuery = '';

      function applyFilters() {
        var visible = 0;
        for (var i = 0; i < items.length; i++) {
          var item = items[i];
          var itemType = item.getAttribute('data-type') || '';
          var itemTitle = (item.getAttribute('data-title') || '').toLowerCase();
          var itemVendor = (item.getAttribute('data-vendor') || '').toLowerCase();
          var itemCve = (item.getAttribute('data-cve') || '').toLowerCase();

          var typeMatch = activeFilter === 'all' || itemType === activeFilter;
          var q = searchQuery.toLowerCase();
          var textMatch = !q ||
            itemTitle.indexOf(q) !== -1 ||
            itemVendor.indexOf(q) !== -1 ||
            itemCve.indexOf(q) !== -1;

          var show = typeMatch && textMatch;
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        }

        if (countEl) {
          countEl.textContent = visible + (visible === 1 ? ' item' : ' items');
        }

        if (emptyEl) {
          emptyEl.style.display = visible === 0 ? 'block' : 'none';
        }
      }

      chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
          chips.forEach(function (c) {
            c.classList.remove('active');
            c.setAttribute('aria-pressed', 'false');
          });
          chip.classList.add('active');
          chip.setAttribute('aria-pressed', 'true');
          activeFilter = chip.getAttribute('data-filter');
          applyFilters();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', function () {
          searchQuery = searchInput.value;
          applyFilters();
        });
      }

      // Inject a Pro upgrade card after the 10th feed item
      if (items.length > 10) {
        var promo = document.createElement('div');
        promo.className = 'feed-promo';
        promo.setAttribute('data-promo', '1');
        promo.innerHTML =
          '<div class="feed-promo-text">' +
          '<p>Get daily digests + alerts for vendors you run.</p>' +
          '<span>PatchBrief Pro &mdash; $9/month</span>' +
          '</div>' +
          '<a class="button button-ghost" href="pricing.html#pro">Upgrade to Pro &rarr;</a>';
        items[9].after(promo);
      }
    })();
    </script>
  </body>
</html>
